{
  "tasks": {
    "local_checkout": "./clone_raycast_sparse.sh --repo https://github.com/raycast/extensions.git",
    "local_pull": "git -C ./repo pull --progress --verbose",
    "run": "deno run -A scripts/run.ts",
    "run-local": "deno run --env-file -A scripts/run.ts",
    "run-local-dev": "deno run --env-file -A scripts/run.ts --no-issues",
    "clean": "deno run -A scripts/clean.ts",
    "reset-local": "git restore data/ docs/ graphics/ README.md && git clean -fd graphics/",
    "quick-local": "deno task reset-local && deno task run-local-dev"
  },
  "imports": {
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@svarta/walk-it": "jsr:@svarta/walk-it@^5.0.1",
    "badge-maker": "npm:badge-maker@^5.0.2",
    "date-fns": "npm:date-fns@^4.1.0",
    "nanoid": "npm:nanoid@^5.1.6",
    "octokit": "npm:octokit@^5.0.5"
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "singleQuote": false,
    "useTabs": false,
    "proseWrap": "preserve"
  },
  "exclude": [
    ".github/",
    "README.md",
    "data/*.json",
    "graphics/",
    "repo/",
    "assets/"
  ]
}
